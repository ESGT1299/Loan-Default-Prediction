# Exclude temporary files
*.tmp
*.log

# Ignore datasets and model files
*.zip
*.pkl
dataset/
datos de kaggle/
artifacts/*
!artifacts/loan_default_pipeline.joblib

# Exclude .png files
*.png
# Exclude Python virtual environment
venv/
.venv/

# Ignore system files
.DS_Store
Thumbs.db

# Exclude compiled Python files
__pycache__/
*.pyc
*.pyo

# Exclude Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Exclude IDE configuration files
.vscode/
.idea/
